# SAP Cloud Integration authentication
# SAP_AUTH_MODE=auto will prefer Basic Auth when credentials are available.
# If SAP_SERVICE_KEY_PATH is set, clientid/clientsecret from the service key are also used as Basic Auth credentials.
SAP_AUTH_MODE=auto

# Option A: technical user (recommended for OData APIs)
SAP_BASIC_USERNAME=
SAP_BASIC_PASSWORD=

# Option B: SAP BTP OAuth2 service key (kept as fallback for non-OData scenarios)
SAP_TOKEN_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=
SAP_CPI_BASE_URL=https://<tenant>.it-cpi-n.hana.ondemand.com

# Optional API tuning
SAP_API_TIMEOUT_MS=30000
SAP_API_MAX_RETRIES=3
SAP_API_PAGE_SIZE=100

# Output and scheduler
OUTPUT_DIR=./output
RETENTION_DAYS=90
CRON_EXPRESSION=0 30 2 * * *
TIMEZONE=Europe/Rome

# Alerting (optional)
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
